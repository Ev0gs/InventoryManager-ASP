@model Product

<h2>Supprimer le produit</h2>

<p>Confirmer la suppression de <strong>@Model.Name</strong> ?</p>

<dl class="row">
	<dt class="col-sm-2">Id</dt>
	<dd class="col-sm-10">@Model.Id</dd>
	<dt class="col-sm-2">Description</dt>
	<dd class="col-sm-10">@Model.Description</dd>
	<dt class="col-sm-2">Prix</dt>
	<dd class="col-sm-10">@Model.Price.ToString("C")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
	<input type="hidden" asp-for="Id" />
	<button type="submit" class="btn btn-danger">Supprimer</button>
	<a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
